NODE_ENV=development
PORT=3000

# Supabase - from Supabase Dashboard > Project Settings > API
# NEVER commit real keys. Use placeholders for .env.example.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_from_supabase_dashboard
SUPABASE_SERVICE_KEY=your_service_role_key_from_supabase_dashboard

# SabPaisa Payment Gateway - from partner.sabpaisa.in / your Account Manager
# On Railway: set these in Variables. SABPAISA_CALLBACK_URL must be your public backend URL.
SABPAISA_CLIENT_CODE=your_client_code
SABPAISA_TRANS_USERNAME=your_trans_username
SABPAISA_TRANS_PASSWORD=your_trans_password
SABPAISA_AUTH_KEY=your_auth_key
SABPAISA_AUTH_IV=your_auth_iv
SABPAISA_MCC=5666
SABPAISA_BASE_URL=https://stage-securepay.sabpaisa.in/SabPaisa/sabPaisaInit?v=1
SABPAISA_CALLBACK_URL=https://your-backend.up.railway.app/payments/callback

# Optional: used as fallback for SABPAISA_CALLBACK_URL if not set
# API_URL=https://your-backend.up.railway.app

# Expo Push (optional - for push notifications)
# EXPO_ACCESS_TOKEN=your_eas_access_token

# Forgot password redirect (optional - defaults to trustopay://reset-password)
# RESET_PASSWORD_REDIRECT_URL=trustopay://reset-password

# Auth: set to "true" to require email verification before login (default: false)
# ENABLE_EMAIL_VERIFICATION=false
